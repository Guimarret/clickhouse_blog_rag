# Optional GitHub PAT used by `versions-refresh` to lift the 60 req/hr
# unauthenticated rate limit. A token with no scopes (public read) is enough.
GH_TOKEN=

# Anthropic API key, used by the Rag_DPR_blog topic-labeling stage when
# Ollama is unavailable / crashing (fallback labeler = Claude Haiku).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
